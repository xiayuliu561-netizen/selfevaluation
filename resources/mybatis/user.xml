<?xml version="1.0" encoding="UTF-8" ?>  <!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mywork.mapper.UserMapper">
	<resultMap type="User" id="userMap">
		<id property="id" column="id" />
		<result property="id" column="id" />
		<result property="no" column="no" />
		<result property="username" column="username" />
		<result property="password" column="password" />
		<result property="name" column="name" />
		<result property="birthday" column="birthday" />
		<result property="tel" column="tel" />
		<result property="sex" column="sex" />
		<result property="post" column="post" />
		<result property="email" column="email" />
		<result property="intime" column="intime" />
		<result property="isadmin" column="isadmin" />
		<result property="status" column="status" />
		<result property="degree" column="degree" />
		<result property="collegeId" column="college_id" />
		<result property="deptId" column="dept_id" />
		<result property="collegeName" column="college_name" />
		<result property="deptName" column="dept_name" />
	</resultMap>
	<select id="getList" parameterType="Map" resultType="List"
		resultMap="userMap">
		SELECT * from User WHERE 1=1
		<if test="deptId != '' and deptId != null ">
			and dept_id =#{deptId} and isadmin = 2
           	</if>
        <if test="checkdeptId != '' and checkdeptId != null ">
			and dept_id =#{checkdeptId} 
           	</if>
        <if test="collegeId != '' and collegeId != null ">
			and college_id =#{collegeId} and isadmin = 2
           	</if>
		<if test="isadmin != '' and isadmin != null ">
			and isadmin =#{isadmin}
           	</if>
		<if test="username != '' and username != null ">
			and username =#{username}
           	</if>
		<if test="password != '' and password != null ">
			and password =#{password}
           	</if>
		<if test="status != '' and status != null ">
			and status =#{status}
           	</if>
        <if test="no != '' and no != null ">
			and no =#{no}
           	</if>
		<if test="excludeId != '' and excludeId != null ">
			and id != #{excludeId}
           	</if>
		<if test="queryname != '' and queryname != null">
			and (username = #{queryname} or no = #{queryname} or name = #{queryname} or email = #{queryname} or tel = #{queryname})
		</if>
		<if test="name != '' and name != null"> and name = #{name} </if>
	</select>
	<!-- 用户登录时验证用户名密码 -->
	<select id="getUserByNameAndPassword" parameterType="User"
		resultType="User" resultMap="userMap">  
        <![CDATA[ 
            SELECT * from user u 
                WHERE u.username = #{username} and u.password=#{password} 
        ]]>
	</select>
	<select id="getById" parameterType="String" resultType="User"
		resultMap="userMap"><![CDATA[  SELECT * from User tmp WHERE tmp.id = #{id} ]]>
	</select>
	<insert id="insert" parameterType="User"><![CDATA[insert into User( 
id,no,username,password,name,birthday,tel,sex,post,email,intime,isadmin,status,degree,college_id,dept_id,college_name,dept_name) values (#{id},#{no},#{username},#{password},#{name},#{birthday},#{tel},#{sex},#{post},#{email},#{intime},#{isadmin},#{status},#{degree},#{collegeId},#{deptId},#{collegeName},#{deptName})
]]></insert>
	<update id="update" parameterType="User"><![CDATA[update User set 
id=#{id},no=#{no},username=#{username},password=#{password},name=#{name},birthday=#{birthday},tel=#{tel},sex=#{sex},post=#{post},email=#{email},intime=#{intime},isadmin=#{isadmin},status=#{status},degree=#{degree},college_id=#{collegeId},dept_id=#{deptId},college_name=#{collegeName},dept_name=#{deptName} where id = #{id}
]]></update>
	<delete id="delete" parameterType="String"><![CDATA[ delete from User  WHERE id = #{id} ]]></delete>
</mapper>
