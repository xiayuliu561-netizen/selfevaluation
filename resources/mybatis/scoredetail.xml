<?xml version="1.0" encoding="UTF-8" ?>  <!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mywork.mapper.ScoreDetailMapper">
	<resultMap type="ScoreDetail" id="scoreDetailMap">
		<id property="id" column="id" />
		<result property="id" column="id" />
		<result property="lessonid" column="lessonid" />
		<result property="teacherid" column="teacherid" />
		<result property="userid" column="userid" />
		<result property="componentName" column="component_name" />
		<result property="score" column="score" />
		<result property="sortno" column="sortno" />
		<result property="sourceStatus" column="source_status" />
		<result property="createdate" column="createdate" />
		<association property="user" column="userid" select="getuser" />
	</resultMap>
	<select id="getuser" parameterType="String" resultType="com.mywork.bean.User">
		<![CDATA[ SELECT * from user tmp WHERE tmp.id = #{userid} ]]>
	</select>
	<select id="getList" parameterType="Map" resultType="List" resultMap="scoreDetailMap">
		SELECT * from score_detail WHERE 1=1
		<if test="lessonid != '' and lessonid != null"> and lessonid = #{lessonid} </if>
		<if test="teacherid != '' and teacherid != null"> and teacherid = #{teacherid} </if>
		<if test="userid != '' and userid != null"> and userid = #{userid} </if>
		<if test="componentName != '' and componentName != null"> and component_name = #{componentName} </if>
		ORDER BY userid ASC,sortno ASC,id ASC
	</select>
	<insert id="insert" parameterType="ScoreDetail"><![CDATA[insert into score_detail(
id,lessonid,teacherid,userid,component_name,score,sortno,source_status,createdate) values (#{id},#{lessonid},#{teacherid},#{userid},#{componentName},#{score},#{sortno},#{sourceStatus},#{createdate})
]]></insert>
	<update id="updateScore" parameterType="ScoreDetail"><![CDATA[update score_detail set
score=#{score},source_status=#{sourceStatus},createdate=#{createdate} where lessonid=#{lessonid} and teacherid=#{teacherid} and userid=#{userid} and component_name=#{componentName}
]]></update>
	<delete id="deleteByLesson" parameterType="Map">
		delete from score_detail WHERE 1=1
		<if test="lessonid != '' and lessonid != null"> and lessonid = #{lessonid} </if>
		<if test="teacherid != '' and teacherid != null"> and teacherid = #{teacherid} </if>
	</delete>
	<delete id="deleteByLessonUser" parameterType="Map">
		delete from score_detail WHERE 1=1
		<if test="lessonid != '' and lessonid != null"> and lessonid = #{lessonid} </if>
		<if test="teacherid != '' and teacherid != null"> and teacherid = #{teacherid} </if>
		<if test="userid != '' and userid != null"> and userid = #{userid} </if>
	</delete>
</mapper>
