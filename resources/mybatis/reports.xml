<?xml version="1.0" encoding="UTF-8" ?>  <!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mywork.mapper.ReportsMapper">
	<resultMap type="Reports" id="reportsMap">
		<id property="id" column="id" />
		<result property="id" column="id" />
		<result property="userid" column="userid" />
		<result property="reports" column="reports" />
		<result property="content1" column="content1" />
		<result property="content2" column="content2" />
		<result property="content3" column="content3" />
		<result property="content4" column="content4" />
		<result property="content5" column="content5" />
		<result property="content6" column="content6" />
		<result property="lessonid" column="lessonid" />
	</resultMap>
	<select id="getList" parameterType="Map" resultType="List"
		resultMap="reportsMap">
		SELECT * from reports WHERE 1=1
		<if test="userid != '' and userid != null"> and userid = #{userid} </if>
		<if test="lessonid != '' and lessonid != null"> and lessonid = #{lessonid} </if>
		<if test="name != '' and name != null"> and name LIKE
			CONCAT(CONCAT('%', #{name}), '%') </if>
	</select>
	<select id="getById" parameterType="String" resultType="Reports"
		resultMap="reportsMap"><![CDATA[  SELECT * from reports tmp WHERE tmp.id = #{id} ]]>
	</select>
	<insert id="insert" parameterType="Reports"><![CDATA[insert into reports( 
id,userid,reports,content1,content2,content3,content4,content5,content6,lessonid) values (#{id},#{userid},#{reports},#{content1},#{content2},#{content3},#{content4},#{content5},#{content6},#{lessonid})
]]></insert>
	<update id="update" parameterType="Reports"><![CDATA[update reports set 
id=#{id},userid=#{userid},reports=#{reports},content1=#{content1},content2=#{content2},content3=#{content3},content4=#{content4},content5=#{content5},content6=#{content6},lessonid=#{lessonid} where id = #{id}
]]></update>
	<delete id="delete" parameterType="String"><![CDATA[ delete from reports  WHERE id = #{id} ]]></delete>
</mapper>